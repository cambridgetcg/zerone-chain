# =============================================================================
# ZERONE Inference Layer — Environment Configuration
# Copy to .env and adjust for your environment: cp .env.example .env
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=zerone
POSTGRES_PASSWORD=zerone-dev
POSTGRES_DB=zerone
POSTGRES_PORT=5432
DATABASE_URL=postgres://zerone:zerone-dev@postgres:5432/zerone?sslmode=disable

# --- Redis --------------------------------------------------------------------
REDIS_ADDR=redis:6379

# --- NATS ---------------------------------------------------------------------
NATS_URL=nats://nats:4222

# --- MinIO (S3-compatible) ----------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=zerone-data

# --- ZERONE Chain -------------------------------------------------------------
# For local dev, use the mock chain stub (default).
# For testnet, override with your node's gRPC endpoint.
CHAIN_GRPC=chain-mock:9090

# --- vLLM Inference Server ----------------------------------------------------
# GPU mode (requires NVIDIA GPU + nvidia-container-toolkit):
#   INFERENCE_RUNTIME=nvidia
# CPU-only dev mode (slow but functional):
#   INFERENCE_RUNTIME=
INFERENCE_RUNTIME=
MODEL_PATH=/models/base/Llama-3.1-8B-Instruct
MAX_MODEL_LEN=2048
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
VLLM_IMAGE=vllm/vllm-openai:latest

# --- API Gateway --------------------------------------------------------------
GATEWAY_ADDR=:8080
GATEWAY_METRICS_ADDR=:9201
GATEWAY_INFERENCE_URL=http://inference:8000
GATEWAY_RATE_LIMIT=10
GATEWAY_BURST=20

# --- Dataset Exporter ---------------------------------------------------------
EXPORTER_METRICS_ADDR=:9200
EXPORTER_CHAIN_GRPC=chain-mock:9090
EXPORTER_POLL_INTERVAL=10s

# --- Payment Bridge -----------------------------------------------------------
PAYMENT_GRPC_ADDR=:9300
PAYMENT_REDIS=redis:6379
PAYMENT_CHAIN_GRPC=chain-mock:9090
PAYMENT_SETTLE_INTERVAL=5m

# --- Blind Storage Node -------------------------------------------------------
STORAGE_NODE_ADDR=:9400
STORAGE_DATA_DIR=/data/chunks

# --- Training Pipeline --------------------------------------------------------
TRAINING_DSN=postgres://zerone:zerone-dev@postgres:5432/zerone?sslmode=disable
